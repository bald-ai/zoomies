.DS_Store

# SwiftPM / Swift compiler build output (includes index store databases like data.mdb).
.build/
dist/
.tmp_cache/
.tmp_home/

# Xcode / SourceKit / derived artifacts (optional, but usually safe to ignore).
DerivedData/
.swiftpm/
*.xcodeproj/
*.xcworkspace/

# Xcode user-specific state.
xcuserdata/
*.xcuserstate
*.xccheckout
*.xcscmblueprint

# IDEs / editors.
.vscode/
.idea/

# Logs.
*.log

# Repo-local planning / scratch artifacts.
agent_tasks/
RELEASE_TODO.md

# Python bytecode (no Python is part of this project).
__pycache__/
*.pyc
